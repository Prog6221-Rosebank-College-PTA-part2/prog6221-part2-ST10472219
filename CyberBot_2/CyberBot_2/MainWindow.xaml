 <Window x:Class="CyberBot_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSafe Bot"
        Height="550"
        Width="950"
        Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock
            Text="CyberSafe Bot"
            FontSize="30"
            FontWeight="Bold"
            Foreground="Cyan"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <!-- CHAT AREA -->
        <RichTextBox
            x:Name="rtbChat"
            Grid.Row="1"
            Margin="10"
            Background="Black"
            Foreground="White"
            FontSize="15"
            IsReadOnly="True"/>

        <!-- INPUT AREA -->
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <TextBox
                x:Name="txtInput"
                Width="550"
                Height="40"
                FontSize="15"
                KeyDown="txtInput_KeyDown"/>

            <Button
                x:Name="btnSend"
                Content="Send"
                Width="120"
                Height="40"
                Margin="10,0,0,0"
                Background="Cyan"
                Foreground="Black"
                FontWeight="Bold"
                Click="btnSend_Click"/>

            <Button
                x:Name="btnClear"
                Content="Clear"
                Width="120"
                Height="40"
                Margin="10,0,0,0"
                Background="Red"
                Foreground="White"
                FontWeight="Bold"
                Click="btnClear_Click"/>
        </StackPanel>

    </Grid>
</Window>

